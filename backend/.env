# ─── Banco de dados ───────────────────────────────────────────────
POSTGRES_DB=mlresearch
POSTGRES_USER=mluser
POSTGRES_PASSWORD=mlpass
DATABASE_URL=postgresql+asyncpg://mluser:mlpass@postgres:5432/mlresearch

# ─── Redis / Celery ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Anthropic (Claude Vision) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (email) ───────────────────────────────────────────────
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL_FROM=noreply@seudominio.com
NOTIFICATION_EMAIL_TO=voce@email.com

# ─── Proxy rotativo para scraping ─────────────────────────────────
# Suporte a qualquer proxy HTTP com autenticação user:pass@host:port
PROXY_URL=http://user:pass@proxy.provider.com:port

# ─── App ──────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=troque-por-uma-chave-segura-gerada-aleatoriamente

# ─── Scheduler ────────────────────────────────────────────────────
# Horário da sincronização diária das tabelas do ML (UTC)
TABLE_SYNC_HOUR=9
TABLE_SYNC_MINUTE=0

# Intervalo entre lotes de scraping (minutos)
BATCH_INTERVAL_MINUTES=30

# Tamanho do lote de produtos
BATCH_SIZE=20
